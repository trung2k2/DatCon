{
  "name": "datcon-electron",
  "version": "3.5.0",
  "description": "DJI DAT log analyzer - Convert DAT files to KML/CSV",
  "main": "dist/main.js",
  "homepage": "/",
  "author": "DatCon Contributors",
  "license": "BSD",
  "scripts": {
    "dev": "concurrently \"npm run electron\" \"npm run react:dev\"",
    "electron": "electron .",
    "react:dev": "vite",
    "build": "npm run build:react && npm run build:electron",
    "build:react": "vite build",
    "build:electron": "tsc src/main.ts src/preload.ts --outDir dist --target es2020 --module commonjs --skipLibCheck --esModuleInterop",
    "pack": "electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css}\"",
    "lint": "eslint src --ext .ts,.tsx,.js,.jsx"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@types/electron": "^1.6.10",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^7.6.0",
    "@typescript-eslint/parser": "^7.6.0",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.0",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "eslint": "^8.57.0",
    "minimatch": "^9.0.4",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0",
    "vite": "^8.0.1"
  }
}
